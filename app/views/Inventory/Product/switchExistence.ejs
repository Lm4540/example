<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../Layouts/Head.ejs') %>
  <link rel="stylesheet" href="assets/libs/choices/choices.min.css">
  <style>
    .choices {
      margin-bottom: 2px;
    }

    #details_body tr td {
      padding-bottom: 10px;
    }
  </style>
</head>
<% options = `<a class="ml-5" href="/inventory" style="width: 150px;"><i class="fas fa-arrow-alt-circle-left mr-3"></i>Atrás</a>`; %>

<body class="<%= darkMode %>">
  <%- include('../../Layouts/SideBar.ejs') %>
  <div id="main">
    <%- include('../../Layouts/NavBar.ejs') %>


    <div class="main-content contanier">

      <div class="form-group">
        <label for="selectSucursal">Sucursal</label>
        <select name="selectSucursal" id="selectSucursal" class="form-control">
          <% sucursals.forEach(sucursal => { %>
          <option value="<%= sucursal.id %>"><%= sucursal.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="originProduct">Producto Origen</label>
        <select name="originProduct" id="originProduct" class="form-control">

        </select>
      </div>

      <div class="form-group">
        <label for="destinoProduct">Producto Destino</label>
        <select name="destinoProduct" id="destinoProduct" class="form-control">
        </select>
      </div>
      <div class="form-group">
        <label for="cant">Cantidad a pasar</label>
        <input name="cant" id="cant" class="form-control" type="number" step="1">
        <small id="disponible" class="text-danger">0 Disponibles</small>
      </div>

      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Redirigir</label>
      </div>

      <button onclick="procesar()" class="btn btn-outline-success mt-5">
        Procesar
      </button>



    </div>

    <%- include('../../Layouts/Footer.ejs') %>
  </div>
</body>
<%- include('../../Layouts/Scripts.ejs') %>
<script src="assets/libs/choices/choices.min.js"></script>
<script>
  var destinoSelect = document.querySelector('#destinoProduct'),
    originSelect = document.querySelector('#originProduct'),
    selectedSucursal = document.querySelector('#selectSucursal'),
    timerOrigin,
    timerDestino,
    destino_last_val = "",
    origin_last_val = "",
    originSearchResult = {};

  const doSearchDestinoProduct = async (val, stock = false) => {
    // Opciones por defecto estan marcadas con un *
    const response = await fetch(`/inventory/products/select2?search=${encodeURIComponent(val)}&onlystock=${stock}&sucursal=${selectedSucursal.value}`, {
      mode: 'cors',
      cache: 'no-cache',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json'
      },
      redirect: 'follow',
      referrerPolicy: 'no-referrer',
    });
    return response.json();
  }

  const choices_destino = new Choices(destinoSelect, {
    'searchResultLimit': 15,
    'searchChoices': false,
    'searchFloor': 3,
  });

  const choices_origin = new Choices(originProduct, {
    'searchResultLimit': 15,
    'searchChoices': false,
    'searchFloor': 3,
  });



  document.addEventListener("DOMContentLoaded", (event) => {


    originSelect.addEventListener('search', async (e) => {
      let valor_actual = e.detail.value;
      if (origin_last_val !== valor_actual) {
        origin_last_val = valor_actual;
        clearTimeout(timerOrigin);
        timerOrigin = setTimeout(async () => {
          let data = await doSearchDestinoProduct(e.detail.value, true);
          originSearchResult = {};
          data.forEach(element => originSearchResult[element.id] = element);

          choices_origin.setChoices(data, 'value', 'label', true);
        }, 500);
      }
    });

    originSelect.addEventListener('change', (e) => {
      let prod = originSearchResult[originSelect.value];
      let stock = prod.stock - prod.reserved;
      document.querySelector('#cant').max = stock;
      document.querySelector('#disponible').innerHTML = `${stock} Disponibles`;
      document.querySelector('#cant').value = 1;
    });


    destinoSelect.addEventListener('search', async (e) => {
      let valor_actual = e.detail.value;
      if (destino_last_val !== valor_actual) {
        destino_last_val = valor_actual;
        clearTimeout(timerDestino);
        timerDestino = setTimeout(async () => {
          let data = await doSearchDestinoProduct(e.detail.value);
          //indexar los datos para tenerlos a la mano

          choices_destino.setChoices(data, 'value', 'label', true);
        }, 500);
      }
    });
  });

  const procesar = async () => {

    let data = {
      destino: destinoSelect.value,
      origin: originSelect.value,
      sucursal: selectedSucursal.value,
      cant: document.querySelector('#cant').value,
    };

    postData('/inventory/product/switch', data)
      .then(data => {
        if (data.status == 'success') {
          successMessage('Operación exitosa');
          /**Redirigir a la pagina del Proveedor*/
          setTimeout(() => {
            if (document.querySelector('#switchCheckDefault').checked) {

              location.href = `/inventory/product/view/${data.data}`;
            }
          }, 1500);

        } else if (data.status == 'errorMessage') {
          e.target.disabled = false;

          return errorMessage(data.message);
        } else {
          return errorMessage('Lo sentimos, ha ocurrido un error, por favor recarga la página he inténtalo nuevamente');
        }
      });
  }
</script>

</html>