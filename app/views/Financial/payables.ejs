<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../Layouts/Head.ejs') %>
  <link rel="stylesheet" href="assets/libs/choices/choices.min.css">
  <style>
    .table-v-middle td {
      vertical-align: middle;
    }

    .card-stats {
      border-left: 4px solid #0d6efd;
    }
  </style>
</head>

<body class="<%= darkMode %>">
  <%- include('../Layouts/SideBar.ejs') %>
  <div id="main">
    <%- include('../Layouts/NavBar.ejs') %>

    <div class="container py-4">
      <div class="row mb-4">
        <div class="col-md-6">
          <h3 class="fw-bold"><i class="fas fa-balance-scale-right mr-4" style="font-size: larger;"></i>Cuentas por Pagar</h3>
          <p class="text-muted">Gestión de obligaciones y saldos vigentes</p>
        </div>
        <div class="col-md-6 text-end">
          <a href="/financial/history" class="btn btn-outline-primary me-2">
            <i class="fas fa-search-dollar mr-2" style="font-size: large;"></i> Historial General
          </a>
          <button class="btn btn-outline-danger  me-2" data-bs-toggle="modal" data-bs-target="#modalNuevaObligacion">
            <i class="fas fa-file-medical mr-2" style="font-size: large;"></i> Nueva Obligación
          </button>
          <button class="btn btn-outline-success" onclick="abrirModalPago()">
            <i class="fas fa-cash-register mr-2" style="font-size: large;"></i> Registrar Pago
          </button>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <div class="row g-3">

            <div class="col-md-6">
              <label for="ordenCuentas">Criterio de Ordenamiento</label>
              <select class="form-select" id="ordenCuentas" onchange="actualizarTabla()">
                <option value="venc_asc">Próximas a vencer (Prioridad)</option>
                <option value="venc_desc">Vencimiento más lejano</option>
                <option value="monto_desc">Monto Mayor</option>
                <option value="monto_asc">Monto Menor</option>
                <option value="fecha_desc">Más nueva (Creación)</option>
                <option value="fecha_asc">Más vieja (Creación)</option>
              </select>
            </div>
            <div class="col-md-2">
              <button onclick="ordenarCuentas()" class="btn btn-outline-success mt-4">Ordenar</button>
            </div>
            <div class="col-md-4 d-flex align-items-center justify-content-end">
              <div class="text-primary p-2 h5">
                Total Pendiente: <span id="deudaTotal">$<%=  Helper.money_format(deudaTotal) %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="table-responsive">
          <table class="table table-hover table-v-middle mb-0" id="tablaCuentas">
            <thead class="">
              <tr>
                <th class="ps-3">Proveedor</th>
                <th>Documento</th>
                <th>Vencimiento</th>
                <th>Monto Original</th>
                <th>Pagado</th>
                <th>Saldo Pendiente</th>
                <th>Estado</th>
                <th class="text-end pe-3">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% 
              accounts.forEach(acc => {
                acc.amount = parseFloat(acc.amount);
                acc.currentBalance = parseFloat(acc.currentBalance);
                
                %>

              <tr>
                <td class="ps-3">
                  <span class="fw-bold"><%= acc.provider_name %></span>
                </td>
                <td><small class="text-muted">#<%= acc.purchase || 'S/N' %></small></td>
                <td>
                  <span class="badge <%= new Date(acc.account_date) < new Date() ? 'bg-danger-subtle text-danger' : 'bg-secondary' %>">
                    <i class="far fa-calendar-alt me-1"></i> <%= acc.account_date %>
                  </span>
                </td>
                <td>$<%= Helper.money_format(acc.amount) %></td>
                <td class="text-success">$<%= Helper.money_format(acc.amount - acc.currentBalance) %></td>
                <td class="fw-bold <%= acc.currentBalance > 0 ? 'text-danger' : '' %>">
                  $<%= Helper.money_format(acc.currentBalance) %>
                </td>
                <td>
                  <% if(acc._status === 'Pendiente') { %>
                  <span class="badge bg-secondary"><i class="fa fa-circle-pause me-1"></i> Pendiente</span>
                  <% } else { %>
                  <span class="badge bg-warning"><i class="fa fa-clock me-1"></i> Parcial</span>
                  <% } %>
                </td>
                <td class="text-end pe-3">
                  <a href="/financial/account/<%= acc.id %>" class="badge bg-primary mr-2 mt-2 ml-2">
                    Ver
                  </a>
                  &nbsp;
                  <span class="badge bg-success mt-2" onclick="abrirModalPagoIndividual('<%= acc.id %>', '<%= acc.provider %>')">
                    Pagar
                  </span>
                </td>
              </tr>

              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <%- include('../Layouts/Footer.ejs') %>
  </div>

  <div class="modal fade" id="modalPago" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Registrar Pago / Abono</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="formPago">
            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label class="form-label fw-bold">Proveedor</label>
                <select class="form-select" id="pagoProviderId" required onchange="cargarCuentasPendientes(this.value)">
                  <option value="">Seleccione proveedor...</option>
                  <% providers.forEach(p => { %>
                  <option value="<%= p.id %>"><%= p.name %> (Deuda: $<%= p.balance - p.payments %>)</option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Monto del Pago</label>
                <input type="number" step="0.01" class="form-control form-control-lg fw-bold" id="pagoTotal" required>
              </div>
              <div class="col-md-6">
                <label class="form-label small">Método de Pago</label>
                <select class="form-select" id="pagoMethod" required>
                  <option value="Transferencia">Trasnferencia Bancaria</option>
                  <option value="Deposito">Deposito Bancario</option>
                  <option value="Efectivo">Efectivo</option>

              </div>
              <div class="col-md-6">
                <label class="form-label small">Referencia / Comprobante</label>
                <input type="text" class="form-control" id="pagoRef" placeholder="Ej: Transf. #12345">
              </div>
              <div class="col-md-6">
                <label class="form-label small">Tipo de Movimiento</label>
                <select class="form-select" id="pagoType">
                  <option value="Pago">Pago (Desembolso)</option>
                  <option value="Descuento">Descuento (Nota de Crédito)</option>
                  <option value="Interes">Interés (Aumento de deuda)</option>
                </select>
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <h6 class="fw-bold mb-0">Distribución de Pago</h6>
              <div class="form-check form-switch">
                <input class="form-check-input" checked="checked" type="checkbox" id="asignacionAuto" onchange="toggleAsignacionAuto()">
                <label class="form-check-label small" for="asignacionAuto">Asignación Automática (FIFO)</label>
              </div>
            </div>

            <div id="contenedorCuentasPendientes" class="border rounded p-3">
              <p class="text-center text-muted my-3">Seleccione un proveedor para ver sus facturas pendientes</p>
            </div>
          </form>
        </div>
        <div class="modal-footer ">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary px-4" onclick="guardarPago()">Procesar Pago</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="modalNuevaObligacion" tabindex="-1" aria-labelledby="modalNuevaObligacionLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-dark text-white">
          <h5 class="modal-title" id="modalNuevaObligacionLabel">Nueva Obligación de Pago</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="formNuevaObligacion">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label fw-bold small">Proveedor</label>
              <select class="form-select" name="provider" id="providerNuevaObligacion">
                <option value="">Seleccione un proveedor...</option>
                <% providers.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold small">Monto de la Deuda</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" min="0.01" step="0.01" class="form-control" name="amount" required placeholder="0.00">
                </div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold small">Fecha de Vencimiento</label>
                <input type="date" class="form-control" name="account_date" required value="<%= new Date().toISOString().split('T')[0] %>">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold small">Compra relacionada (ID especifico)</label>
              <input type="number" class="form-control" name="purchase" placeholder="Ej: 1050">
            </div>
            <div class="mb-0">
              <label class="form-label fw-bold small">Notas / Observaciones</label>
              <textarea class="form-control" name="notes" rows="2" placeholder="Detalles sobre el crédito..."></textarea>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary px-4" id="btnGuardarObligacion">
              <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
              Guardar Obligación
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>


</body>
<%- include('../Layouts/Scripts.ejs') %>
<script src="assets/libs/choices/choices.min.js"></script>
<script>
  let cuentasPendientes = [];
  let cuentaPrioritaria = null;
  const formPago = document.getElementById('formPago');
  const inputTotalPago = document.getElementById('pagoTotal');
  const checkAuto = document.getElementById('asignacionAuto');
  const btnGuardar = document.getElementById('btnGuardarPago');



  async function cargarCuentasPendientes(providerId) {
    if (!providerId) {
      document.getElementById('contenedorCuentasPendientes').innerHTML = '<p class="text-center text-muted my-3">Seleccione un proveedor...</p>';
      return;
    }

    try {
      const response = await fetch(`/financial/api/pending-accounts/${providerId}`);
      cuentasPendientes = await response.json();
      renderizarTablaCuentas();
    } catch (error) {
      console.error("Error:", error);
      alert("No se pudieron cargar las cuentas del proveedor.");
    }
  }

  function renderizarTablaCuentas() {
    const container = document.getElementById('contenedorCuentasPendientes');
    const isAuto = checkAuto.checked;
    console.log(cuentasPendientes)

    if (cuentasPendientes.length === 0) {
      container.innerHTML = '<div class="alert alert-info mb-0">Este proveedor no tiene facturas pendientes. El monto se registrará como saldo a favor.</div>';
      return;
    }

    let html = `
        <table class="table table-sm table-borderless align-middle mb-0">
            <thead><tr class="text-muted small"><th>Factura</th><th>Saldo</th><th width="140">Abono</th></tr></thead>
            <tbody>
                ${cuentasPendientes.map(acc => `
                    <tr>
                        <td>
                            <div class="fw-bold text-primary">#${acc.purchase || 'Manual'}</div>
                            <div class="small text-muted">${acc.account_date}</div>
                        </td>
                        <td class="fw-bold ">$${acc.currentBalance}</td>
                        <td>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" step="0.01" class="form-control input-abono" 
                                    data-id="${acc.id}" data-max="${acc.currentBalance}" 
                                    value="0.00" ${isAuto ? 'readonly bg-light' : ''} 
                                    oninput="recalcularTotalDesdeAbonos()">
                            </div>
                        </td>
                    </tr>
                `).join('')}
            </tbody>
        </table>`;

    container.innerHTML = html;
    if (isAuto) aplicarFIFO();
  }

  function aplicarFIFO() {
    let disponible = parseFloat(inputTotalPago.value) || 0;
    let otrosInputs = null;
    if (cuentaPrioritaria) {
      const inputPrioritario = document.querySelector(`.input-abono[data-id="${cuentaPrioritaria}"]`);

      if (inputPrioritario) {
        const max = parseFloat(inputPrioritario.dataset.max);
        if (disponible >= max) {
          inputPrioritario.value = max.toFixed(2);
          disponible -= max;
        } else {
          inputPrioritario.value = disponible.toFixed(2);
          disponible = 0;
        }
      }

      otrosInputs = document.querySelectorAll(`.input-abono:not([data-id="${cuentaPrioritaria}"])`);
    } else {
      otrosInputs = document.querySelectorAll(`.input-abono`);
    }

    console.log(disponible, otrosInputs, cuentaPrioritaria)

    otrosInputs.forEach(input => {
      const max = parseFloat(input.dataset.max);
      if (disponible >= max) {
        input.value = max.toFixed(2);
        disponible -= max;
      } else if (disponible > 0) {
        input.value = disponible.toFixed(2);
        disponible = 0;
      } else {
        input.value = "0.00";
      }
    });
  }



  inputTotalPago.addEventListener('input', () => {
    if (checkAuto.checked) aplicarFIFO();
  });

  function toggleAsignacionAuto() {
    renderizarTablaCuentas();
  }

  async function guardarPago() {
    const provider_id = document.getElementById('pagoProviderId').value;
    const total_amount = parseFloat(inputTotalPago.value);

    if (!provider_id || !total_amount) {
      return errorMessage('ingrese una cantidad y Seleccione un proveedor');
    }

    const ref = document.getElementById('pagoRef').value;
    if (ref.length < 4) {
      return errorMessage('ingrese una referencia válida');
    }


    const details = [];
    document.querySelectorAll('.input-abono').forEach(input => {
      const amount = parseFloat(input.value);
      if (amount > 0) {
        details.push({
          account_id: input.dataset.id,
          amount: amount,
          type: document.getElementById('pagoType').value
        });
      }
    });

    const data = {
      provider_id,
      total_amount,
      payment_method: document.getElementById('pagoMethod').value,
      ref,
      type: document.getElementById('pagoType').value,
      details
    };

    try {
      const response = await fetch('/financial/api/process-payment', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const res = await response.json();
      if (res.success) {
        location.reload();
      } else {
        return errorMessage("Error: " + res.message);
      }
    } catch (error) {
      return errorMessage("Error de conexión con el servidor.");
    }
  }

  const modalPago = new bootstrap.Modal(document.getElementById('modalPago'));
  const modalNuevaObligacion = new bootstrap.Modal(document.getElementById('modalNuevaObligacion'));
  const abrirModalPago = (provider = null) => {
    modalPago.show();
  }

  document.getElementById('formNuevaObligacion').addEventListener('submit', async function(e) {
    e.preventDefault();

    const btn = document.getElementById('btnGuardarObligacion');
    const spinner = btn.querySelector('.spinner-border');
    const formData = new FormData(this);
    let data = Object.fromEntries(formData.entries());
    data.amount = parseFloat(data.amount);
    data.provider = parseInt(data.provider);
    console.log(data);

    if (isNaN(data.amount) || data.amount <= 0) {
      return errorMessage("El monto debe ser un valor positivo.");
    }

    if (isNaN(data.provider) || data.provider < 1 || data.account_date == "") {
      return errorMessage("Complete correctamente los campos de fecha y proveedor.");
    }

    try {
      btn.disabled = true;
      spinner.classList.remove('d-none');

      const response = await fetch('/financial/api/create-account', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (response.ok) {
        const modal = bootstrap.Modal.getInstance(document.getElementById('modalNuevaObligacion'));
        modal.hide();
        this.reset();
        location.reload();
      } else {
        alert(result.message || "Error al registrar la obligación.");
      }
    } catch (error) {
      console.error("Error Fetch:", error);
      alert("Error crítico de conexión.");
    } finally {
      btn.disabled = false;
      spinner.classList.add('d-none');
    }
  });

  const choices_provider = new Choices(document.getElementById('providerNuevaObligacion'), {
    'searchResultLimit': 15,
    'searchChoices': true,
    'searchFloor': 3,
  });

  const choices_pago_provider = new Choices(document.getElementById('pagoProviderId'));
  const ordenarCuentas = () => {
    let orden = document.getElementById('ordenCuentas').value;
    document.location.href = `/financial/payables?sort=${orden}`;

  }

  abrirModalPagoIndividual = (accountId, providerId) => {
    cuentaPrioritaria = accountId;
    checkAuto.checked = true;
    choices_pago_provider.setChoiceByValue(providerId);
    cargarCuentasPendientes(providerId);
    modalPago.show();

  }
</script>


</html>