<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../Layouts/Head.ejs') %>
</head>

<body class="<%= darkMode %>">
  <%- include('../../Layouts/SideBar.ejs') %>
  <div id="main">
    <%- include('../../Layouts/NavBar.ejs') %>
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
          Verificación de Arqueo <br><%= cash.name %><br> <%= Helper.date_to_spanish(arqueo.createdAt) %>
        </h4>
        <span class="badge bg-secondary">Estado: <%= arqueo.status %></span>
      </div>

      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header  bg-transparent py-3">
              <h6 class="mb-0 fw-bold">Desglose registrado por: <span class="text-info"><%= arqueo.cashier_user %></span></h6>
            </div>
            <div class="card-body">
              <div class="row g-2">
                <% 
                           Object.entries(denominations).forEach(([val, qty]) => { 
                        %>
                <div class="col-md-6 mb-2">
                  <div class="p-2 border border-secondary rounded d-flex justify-content-between align-items-center">
                    <span class="small text-muted"><%= _labels[val] || '$'+Helper.money_format(val) %></span>
                    <span class="fw-bold">x <%= qty %></span>
                    <span class="text-primary fw-bold">$<%= Helper.money_format(val * qty) %></span>
                  </div>
                </div>
                <% }) %>
              </div>
            </div>
            <div class="card-footer  text-center py-3">
              <div class="small text-muted text-uppercase mb-1">Total Físico Reportado</div>
              <h2 class="fw-bold mb-0">$<%= Helper.money_format(arqueo.physical_balance) %></h2>

              <div class="small text-muted text-uppercase mb-1">Saldo en Consignacion</div>
              <h2 class="fw-bold mb-0">$<%= Helper.money_format(arqueo.consigned_amount) %></h2>
            </div>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
              <h6 class="fw-bold text-muted small text-uppercase mb-3">Resumen de Diferencias</h6>
              <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between bg-transparent px-0">
                  <span>Efectivo + Consignación:</span>
                  <span class="fw-bold">$<%= Helper.money_format(parseFloat(arqueo.physical_balance) + parseFloat(arqueo.consigned_amount)) %></span>
                </li>
                <li class="list-group-item d-flex justify-content-between bg-transparent px-0">
                  <span>Saldo en Sistema:</span>
                  <span class="fw-bold">$<%= Helper.money_format(arqueo.system_balance) %></span>
                </li>
                <li class="list-group-item d-flex justify-content-between bg-transparent px-0 border-top-2">
                  <span class="h5">Diferencia:</span>
                  <% if (arqueo.difference < 0) { %>
                  <span class="h5 fw-bold text-danger">
                    FALTANTE: $<%= Helper.money_format(arqueo.difference) %>
                  </span>

                  <% } else if (arqueo.difference > 0) { %>
                  <span class="h5 fw-bold text-primary">
                    SOBRANTE: $<%= Helper.money_format(arqueo.difference) %>
                  </span>

                  <% } else { %>

                  <span class="h5 fw-bold text-success">
                    CUADRADO
                  </span>
                  <% } %>
                </li>
              </ul>
            </div>
          </div>

          <div class="card border-0 shadow-sm bg-warning-subtle">
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label fw-bold small">Nota de Verificación</label>
                <textarea id="verifier_notes" class="form-control border-warning-subtle" rows="3" placeholder="Escriba observaciones encontradas durante la verificación..."><%= arqueo.notes %></textarea>
              </div>

              <div class="d-grid gap-2">
                <% if (user.name == arqueo.cashier_user) { %>

                <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmVerify('Rechazado')">
                  Corregir y Volver a Comenzar
                </button>

                <% } else { %>
                <button type="button" class="btn btn-warning fw-bold py-2" onclick="confirmVerify('Verificado')">
                  Confirmar y Verificar
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmVerify('Rechazado')">
                  Rechazar Arqueo
                </button>

                <p class="text-muted small mt-3 text-center">
                  <i class="fa fa-info-circle me-1"></i> Al verificar, se registrará su usuario (<strong><%= user.name %></strong>) como responsable de la supervisión.
                </p>

                <% } %>
              </div>
            </div>
          </div>


        </div>
      </div>
    </div>
    <%- include('../../Layouts/Footer.ejs') %>
  </div>
</body>
<%- include('../../Layouts/Scripts.ejs') %>

<% if (user.name == arqueo.cashier_user) { %>
<script>
  async function confirmVerify(action) {
    if (!confirm(`Volvera al conteo ¿Esta seguro?`)) return;

    const data = {
      closing_id: '<%= arqueo.id %>',
      action: 'Delete',
      notes: ''
    };

    try {
      const response = await fetch('/financial/api/verify-arqueo', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const res = await response.json();
      if (res.success) {
        window.location.reload()
      } else {
        return errorMessage("Error: " + res.message);
      }
    } catch (error) {
      return errorMessage("Error de comunicación con el servidor.");
    }
  }
</script>

<% } else { %>

<script>
  async function confirmVerify(action) {
    if (!confirm(`¿Está seguro de marcar este arqueo como ${action}?`)) return;

    const data = {
      closing_id: '<%= arqueo.id %>',
      action: action,
      notes: document.getElementById('verifier_notes').value
    };

    try {
      const response = await fetch('/financial/api/verify-arqueo', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const res = await response.json();
      if (res.success) {
        successMessage("Verificación completada correctamente.");
        localStorage.removeItem(`arqueo_cache_<%= cash.id %>`);
        window.location.href = '/pos';
      } else {
        return errorMessage("Error: " + res.message);
      }
    } catch (error) {
      console.error(error);
      return errorMessage("Error de comunicación con el servidor.");
    }
  }
</script>

<% } %>



</html>