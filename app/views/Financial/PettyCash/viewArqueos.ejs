<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../../Layouts/Head.ejs') %>
</head>

<body class="<%= darkMode %>">
  <%- include('../../Layouts/SideBar.ejs') %>
  <div id="main">
    <%- include('../../Layouts/NavBar.ejs') %>
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
          Historial de Cuadre Diario <%= cash.name %>
        </h4>
      </div>

      <div class="row g-4">
        <div class="col-12 table-responsive">
          <table class="table sm table-bordered table-hover">
            <thead>
              <tr>
                <th>Creado</th>
                <th>Verificado</th>
                <th>Monto Fisico</th>
                <th>Monto en Consignación</th>
                <th>Monto en Caja</th>
                <th>Diferencia</th>
                <th>Opt</th>
              </tr>
            </thead>

            <tbody>
              <% arqueos.forEach(ele => { %>

              <tr>
                <td><%= Helper.date_to_spanish(ele.createdAt) %><br>Por: <%= ele.cashier_user %></td>
                <td><%= Helper.date_to_spanish(ele.verifiedAt) %><br>Por: <%= ele.verifier_user %><br></td>
                <td>$<%= Helper.money_format(ele.physical_balance) %></td>
                <td>$<%= Helper.money_format(ele.consigned_amount) %></td>
                <td>$<%= Helper.money_format(ele.system_balance) %></td>
                <td>$<%= Helper.money_format(ele.difference) %></td>
                <td><a href="/financial/view-arqueos/<%= ele.id %>" class="badge bg-purple">Ver</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>

        </div>
      </div>
    </div>
    <%- include('../../Layouts/Footer.ejs') %>
  </div>
</body>
<%- include('../../Layouts/Scripts.ejs') %>





</html>