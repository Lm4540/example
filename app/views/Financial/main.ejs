<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../Layouts/Head.ejs') %>
  <style>
    .icon-card i {
      font-size: 3rem;
      padding-top: 20%;
    }

    .icon-card p {
      padding-top: 60%;
      font-weight: 550;
      font-size: 1rem;
      margin-bottom: 15px;
      ;
    }
  </style>
</head>

<body class="<%= darkMode %>">
  <%- include('../Layouts/SideBar.ejs') %>
  <div id="main">
    <%- include('../Layouts/NavBar.ejs') %>
    <div class="container-fluid py-4">
      <h2 class="fw-bold mb-4">Panel de Control Financiero</h2>

      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body">
              <h6 class="text-uppercase small opacity-75">Deuda Total Pendiente</h6>
              <h2 class="fw-bold mb-0">$<%= stats.totalDeuda.toLocaleString() %></h2>
              <i class="fa fa-hand-holding-dollar position-absolute end-0 bottom-0 m-3 fs-1 opacity-25"></i>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body">
              <h6 class="text-uppercase small opacity-75">Pagos Realizados (Mes)</h6>
              <h2 class="fw-bold mb-0">$<%= stats.totalPagadoMes.toLocaleString() %></h2>
              <i class="fa fa-money-check-dollar position-absolute end-0 bottom-0 m-3 fs-1 opacity-25"></i>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm border-start border-4 border-warning">
            <div class="card-body">
              <h6 class="text-uppercase small text-muted">Acciones Rápidas</h6>
              <div class="btn-group w-100">
                <a href="/financial/payables" class="btn btn-sm btn-outline-warning">Gestionar CXP</a>
                <a href="/financial/history" class="btn btn-sm btn-outline-secondary">Historial CXP</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-header fw-bold py-3">Top 5 Proveedores (Mayor Deuda)</div>
            <div class="card-body">
              <canvas id="chartProveedores"></canvas>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-header  fw-bold py-3">Calendario de Pagos Pendientes (A Proveedores)</div>
            <div class="card-body">
              <canvas id="chartVencimientos"></canvas>
            </div>
          </div>
        </div>
      </div>
  
      <div class="row mt-4">
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header  py-3 d-flex justify-content-between align-items-center">
              <h5 class="card-title mb-0 fw-bold">
                <i class="fa fa-clock-rotate-left me-2 text-warning"></i>Próximos Obligaciones por Vencer (CXP)
              </h5>
              <a href="/financial/payables" class="btn btn-sm btn-link text-decoration-none">Ver todas</a>
            </div>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="">
                  <tr class="small text-uppercase text-muted">
                    <th>Proveedor</th>
                    <th>Referencia</th>
                    <th>Vencimiento</th>
                    <th>Días Restantes</th>
                    <th class="text-end">Saldo Pendiente</th>
                    <th class="text-center">Acción</th>
                  </tr>
                </thead>
                <tbody>
                  <% if(proximosVencimientos.length > 0) { %>
                  <% proximosVencimientos.forEach(acc => { 
                                const hoy = new Date();
                                hoy.setHours(0,0,0,0);
                                const vto = new Date(acc.account_date);
                                const diffTime = vto - hoy;
                                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                
                                let badgeClass = "bg-success";
                                if(diffDays < 0) badgeClass = "bg-danger";
                                else if(diffDays <= 3) badgeClass = "bg-warning";
                            %>
                  <tr>
                    <td>
                      <span class="fw-bold"><%= providers[acc.provider] %></span>
                    </td>
                    <td><span class="badge bg-primary  border">#<%= acc.purchase || 'Manual' %></span></td>
                    <td><%= acc.account_date %></td>
                    <td>
                      <span class="badge <%= badgeClass %>">
                        <%= diffDays < 0 ? 'Vencida (' + Math.abs(diffDays) + 'd)' : (diffDays === 0 ? 'Vence hoy' : 'En ' + diffDays + ' días') %>
                      </span>
                    </td>
                    <td class="text-end fw-bold">
                      <% 
                                        const saldo = parseFloat(acc.amount); 
                                    %>
                      $<%= saldo.toFixed(2) %>
                    </td>
                    <td class="text-center">

                      <a href="/financial/account/<%= acc.id %>" class="badge bg-purple">
                        <i class="fa fa-eye"></i> Ver
                      </a>
                    </td>
                  </tr>
                  <% }) %>
                  <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center py-4 text-muted">No hay cuentas pendientes de pago.</td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('../Layouts/Footer.ejs') %>
  </div>
</body>
<%- include('../Layouts/Scripts.ejs') %>
<script src="assets/js/chart.js"></script>
<script>
  const ctxProv = document.getElementById('chartProveedores');
  const dataProv = JSON.parse('<%- JSON.stringify(chartData.proveedores) %>');

  new Chart(ctxProv, {
    type: 'doughnut',
    data: {
      labels: dataProv.map(p => p.name),
      datasets: [{
        data: dataProv.map(p => p.saldo),
        backgroundColor: ['#d91424', '#9f1cd4', '#20bdaa', '#d63384', '#d99c0d']
      }]
    },
    options: {
      plugins: {
        legend: {
          position: 'bottom'
        }
      }
    }
  });

  // 2. Gráfico de Vencimientos (Bar)
  const ctxVenc = document.getElementById('chartVencimientos');
  const dataVenc = JSON.parse('<%- JSON.stringify(chartData.vencimientos) %>');

  new Chart(ctxVenc, {
    type: 'bar',
    data: {
      labels: dataVenc.map(v => v.fecha),
      datasets: [{
        label: 'Monto a Pagar ($)',
        data: dataVenc.map(v => v.total),
        backgroundColor: '#ffc107'
      }]
    },
    options: {
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });

  Chart.defaults.borderColor = 'rgba(255, 255, 255, 0.1)';
  document.addEventListener("DOMContentLoaded", function() {
    const darkModeControl = document.querySelector("#darkModeControl");
    if (darkModeControl.checked) {
      Chart.defaults.color = '#e9ecef';
      Chart.defaults.scales.category.ticks.color = '#e9ecef'; 
        Chart.defaults.scales.linear.ticks.color = '#e9ecef';
    }

    darkModeControl.addEventListener("change", function() {
      if (this.checked) {
        Chart.defaults.color = '#e9ecef';
        Chart.defaults.scales.category.ticks.color = '#e9ecef'; 
        Chart.defaults.scales.linear.ticks.color = '#e9ecef';
        Chart.defaults.scale.grid.color = 'rgba(233, 236, 239, 0.1)';
      } else {
        Chart.defaults.color = '#121110';
        Chart.defaults.scales.category.ticks.color = '#121110'; 
        Chart.defaults.scales.linear.ticks.color = '#121110';
        Chart.defaults.scale.grid.color = 'rgba(233, 236, 239, 0.1)';
      }
    });
  });
</script>

</html>